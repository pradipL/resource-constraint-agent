# openai
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# tavily
TAVILY_API_KEY=tvly-your-key-here

# qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# Agent budget controls
MAX_LLM_CALLS=15
MAX_COMPLETION_TOKENS=16384   # total completion token budget across the whole session
MAX_TOKEN_LIMIT=20000             # total token cap (prompt + completion); 0 = disabled
SUMMARY_TOKEN_BUFFER=500      # tokens reserved below MAX_TOKEN_LIMIT for the progress-tracker summary response
